---
interface Props {
  text: string;
  href: string;
  variant?: 'dark' | 'light';
  icon?: boolean;
}

const { text, href, variant = 'dark', icon = true } = Astro.props;
const isDark = variant === 'dark';
---

<a
  href={href}
  class={`inline-block px-6 py-3 font-display text-sm font-600 uppercase tracking-widest transition-colors ${
    isDark
      ? 'bg-brand-teal text-brand-deep-slate hover:bg-deep-teal'
      : 'bg-brand-teal text-brand-deep-slate hover:bg-deep-teal'
  }`}
>
  {text}
  {icon && ' →'}
</a>
