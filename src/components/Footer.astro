---
// Minimal footer with NK mark, nav columns, social links
---

<footer class="bg-brand-deep-slate text-brand-text-light py-16 px-6">
  <div class="mx-auto max-w-content">
    <!-- NK Mark + Tagline -->
    <div class="mb-12 pb-12 border-b border-brand-mid-slate">
      <h3 class="font-display text-2xl font-700 mb-2">NAUMAN KHAN</h3>
      <p class="text-brand-text-light-3 text-sm">Founder · Operator · Venture Partner</p>
    </div>

    <!-- Three-column nav + social -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-8">
      <!-- Column 1: Marketing -->
      <div>
        <h4 class="font-mono text-xs text-brand-teal tracking-widest uppercase mb-4">Marketing</h4>
        <ul class="space-y-2">
          <li><a href="/marketing/fractional-cmo" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">Fractional CMO</a></li>
          <li><a href="/marketing/ampere-digital" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">Ampere Digital</a></li>
        </ul>
      </div>

      <!-- Column 2: AI -->
      <div>
        <h4 class="font-mono text-xs text-brand-teal tracking-widest uppercase mb-4">AI</h4>
        <ul class="space-y-2">
          <li><a href="/ai/aai" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">aAi</a></li>
          <li><a href="/ai/amos" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">amOS</a></li>
          <li><a href="/ai/avos" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">avOS</a></li>
        </ul>
      </div>

      <!-- Column 3: Site -->
      <div>
        <h4 class="font-mono text-xs text-brand-teal tracking-widest uppercase mb-4">Site</h4>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">About</a></li>
          <li><a href="/ventures" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">Ventures</a></li>
          <li><a href="/thinking" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">Thinking</a></li>
          <li><a href="/connect" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">Connect</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom line: socials + copyright -->
    <div class="pt-8 border-t border-brand-mid-slate flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div class="flex gap-4">
        <a href="https://linkedin.com" class="text-xs text-brand-text-light-3 hover:text-brand-teal transition">LinkedIn</a>
        <a href="mailto:nauman@ampere.ai" class="text-xs text-brand-text-light-3 hover:text-brand-teal transition">Email</a>
      </div>
      <p class="text-xs text-brand-text-light-3">© 2026 Nauman Khan. All rights reserved.</p>
    </div>
  </div>
</footer>
