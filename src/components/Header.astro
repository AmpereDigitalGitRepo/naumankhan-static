---
// Fixed top-bar header with NK logo, hamburger, and persistent Connect CTA
---

<header
  class="fixed top-0 left-0 right-0 z-40 px-6 py-4 transition-colors duration-300"
  id="header"
>
  <div class="mx-auto flex max-w-content items-center justify-between">
    <!-- Logo mark left -->
    <a href="/" class="flex items-center gap-3 text-brand-text-light hover:opacity-80 transition">
      <div class="h-6 w-6 rounded bg-brand-teal flex items-center justify-center">
        <span class="text-xs font-bold text-brand-deep-slate">NK</span>
      </div>
      <span class="text-sm font-medium hidden sm:inline">NAUMAN KHAN</span>
    </a>

    <!-- Right group: Connect + Hamburger -->
    <div class="flex items-center gap-4">
      <a
        href="/connect"
        class="hidden sm:block px-4 py-2 border border-brand-teal text-brand-teal hover:bg-brand-teal hover:text-brand-deep-slate transition-colors text-sm font-medium uppercase tracking-wider"
      >
        Connect →
      </a>
      <button
        id="hamburger"
        class="p-2 text-brand-text-light hover:text-brand-teal transition"
        aria-label="Menu"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('header');
  const hamburger = document.getElementById('hamburger');

  // Scroll-triggered header styling
  window.addEventListener('scroll', () => {
    if (window.scrollY > 100) {
      header?.classList.add('bg-brand-deep-slate/95', 'backdrop-blur-md', 'border-b', 'border-brand-mid-slate');
      header?.classList.remove('bg-transparent');
    } else {
      header?.classList.remove('bg-brand-deep-slate/95', 'backdrop-blur-md', 'border-b', 'border-brand-mid-slate');
      header?.classList.add('bg-transparent');
    }
  });

  // Hamburger menu toggle
  hamburger?.addEventListener('click', () => {
    const menu = document.getElementById('flyout-menu');
    if (menu) {
      menu.classList.toggle('active');
    }
  });
</script>
