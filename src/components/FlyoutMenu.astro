---
// Full-screen flyout menu with numbered items and GSAP stagger
---

<div
  id="flyout-menu"
  class="fixed inset-0 z-30 hidden flex-col bg-brand-deep-slate/98 backdrop-blur-md"
>
  <!-- Close button -->
  <div class="flex justify-end p-6">
    <button
      id="close-menu"
      class="p-2 text-brand-teal hover:opacity-80 transition"
      aria-label="Close menu"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Menu items -->
  <nav class="flex-1 px-6 py-8">
    <ul class="space-y-6">
      <li class="menu-item">
        <span class="text-xs font-mono text-brand-teal tracking-widest">01</span>
        <a href="/about" class="block text-6xl sm:text-7xl font-display font-700 text-brand-text-light hover:text-brand-teal transition">
          ABOUT
        </a>
      </li>
      <li class="menu-item">
        <span class="text-xs font-mono text-brand-teal tracking-widest">02</span>
        <a href="/marketing" class="block text-6xl sm:text-7xl font-display font-700 text-brand-text-light hover:text-brand-teal transition">
          MARKETING
        </a>
        <ul class="ml-8 mt-2 space-y-1">
          <li><a href="/marketing/fractional-cmo" class="text-lg text-brand-text-light-3 hover:text-brand-teal transition">→ Fractional CMO</a></li>
          <li><a href="/marketing/ampere-digital" class="text-lg text-brand-text-light-3 hover:text-brand-teal transition">→ Ampere Digital</a></li>
        </ul>
      </li>
      <li class="menu-item">
        <span class="text-xs font-mono text-brand-teal tracking-widest">03</span>
        <a href="/ai" class="block text-6xl sm:text-7xl font-display font-700 text-brand-text-light hover:text-brand-teal transition">
          AI
        </a>
        <ul class="ml-8 mt-2 space-y-1">
          <li><a href="/ai/aai" class="text-lg text-brand-text-light-3 hover:text-brand-teal transition">→ aAi</a></li>
          <li><a href="/ai/amos" class="text-lg text-brand-text-light-3 hover:text-brand-teal transition">→ amOS</a></li>
          <li><a href="/ai/avos" class="text-lg text-brand-text-light-3 hover:text-brand-teal transition">→ avOS</a></li>
        </ul>
      </li>
      <li class="menu-item">
        <span class="text-xs font-mono text-brand-teal tracking-widest">04</span>
        <a href="/ventures" class="block text-6xl sm:text-7xl font-display font-700 text-brand-text-light hover:text-brand-teal transition">
          VENTURES
        </a>
      </li>
      <li class="menu-item">
        <span class="text-xs font-mono text-brand-teal tracking-widest">05</span>
        <a href="/thinking" class="block text-6xl sm:text-7xl font-display font-700 text-brand-text-light hover:text-brand-teal transition">
          THINKING
        </a>
      </li>
      <li class="menu-item">
        <span class="text-xs font-mono text-brand-teal tracking-widest">06</span>
        <a href="/connect" class="block text-6xl sm:text-7xl font-display font-700 text-brand-text-light hover:text-brand-teal transition">
          CONNECT
        </a>
      </li>
    </ul>
  </nav>

  <!-- Footer -->
  <div class="px-6 py-8 border-t border-brand-mid-slate flex justify-between items-center">
    <span class="text-sm text-brand-text-light">NAUMAN KHAN</span>
    <div class="flex gap-4">
      <a href="https://linkedin.com" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">LinkedIn</a>
      <a href="mailto:nauman@ampere.ai" class="text-sm text-brand-text-light-3 hover:text-brand-teal transition">Email</a>
    </div>
  </div>
</div>

<script>
  const menu = document.getElementById('flyout-menu');
  const closeBtn = document.getElementById('close-menu');
  const hamburger = document.getElementById('hamburger');

  function toggleMenu() {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  }

  closeBtn?.addEventListener('click', toggleMenu);
  hamburger?.addEventListener('click', toggleMenu);

  // Close menu when clicking on a link
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', toggleMenu);
  });
</script>

<style>
  #flyout-menu {
    display: none;
  }

  #flyout-menu.active {
    display: flex;
  }

  .menu-item {
    opacity: 0;
    transform: translateX(20px);
  }
</style>
