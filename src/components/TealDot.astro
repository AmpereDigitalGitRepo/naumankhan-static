---
// Animated teal accent dot — breathe + nk-ping keyframes on load
---

<div class="relative inline-block h-3 w-3">
  <div class="absolute inset-0 rounded-full bg-brand-teal animate-ping"></div>
  <div class="absolute inset-0 rounded-full bg-brand-teal"></div>
</div>

<style>
  @keyframes nkBreathe {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.2);
      opacity: 0.8;
    }
  }

  .animate-ping {
    animation: nkPing 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes nkPing {
    0%, 100% {
      opacity: 1;
    }
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }
</style>
