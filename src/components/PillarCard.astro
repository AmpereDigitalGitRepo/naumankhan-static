---
interface Props {
  title: string;
  description: string;
  link?: string;
  variant?: 'dark' | 'light';
  borderSize?: 'sm' | 'lg';
}

const { title, description, link, variant = 'dark', borderSize = 'sm' } = Astro.props;
const isDark = variant === 'dark';
const borderClass = borderSize === 'lg' ? 'border-l-4' : 'border-l-2';
---

<div class={`pl-6 py-4 ${borderClass} border-brand-teal ${isDark ? 'bg-brand-slate text-brand-text-light' : 'bg-white text-brand-text-dark'}`}>
  <h3 class="font-display text-lg font-600 mb-2">{title}</h3>
  <p class="text-sm mb-4">{description}</p>
  {link && (
    <a href={link} class="text-brand-teal hover:opacity-80 transition text-sm font-medium">
      Learn more →
    </a>
  )}
</div>
